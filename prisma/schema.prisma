// Vita Fitness App — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum GoalStatus {
  ACTIVE
  PAUSED
  ACHIEVED
  ARCHIVED
}

enum HabitCadence {
  DAILY
  WEEKLY_N
  SPECIFIC_DAYS
  EVERY_OTHER
  WEEKDAYS
  WEEKENDS
}

enum WorkoutStatus {
  PLANNED
  DONE
  SKIPPED
  MOVED
  MISSED         // end-of-day rollover: was PLANNED, never completed, no constraint blocked it
  AUTO_SKIPPED   // end-of-day rollover: was PLANNED, blocked by an active PlannerConstraint
}

enum CompletionStatus {
  DONE
  MISSED
  SKIPPED
  PENDING
}

enum CompletionSource {
  MANUAL
  WEARABLE_AUTO
  ROUTINE
  ROLLOVER_MISS
}

enum HabitTrackingMode {
  MANUAL          // user taps to complete
  WEARABLE_AUTO   // resolves from HealthDaily at end of day
  HYBRID          // user can tap, but also auto-resolves if not tapped
}

enum MetricComparison {
  GTE   // value >= target (steps, active minutes)
  LTE   // value <= target (resting HR, sleep latency)
  EQ    // exact match (rare)
}

// ─── Auth & Accounts ─────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailVerified        DateTime?
  emailVerifyToken     String?   @unique
  passwordHash         String?
  name                 String?
  avatarUrl            String?
  dob                  DateTime?
  sex                  String?
  heightCm             Float?
  activityLevel        String?
  goalWeightKg         Float?
  medicalNotes         String?
  onGlp1               Boolean   @default(false)  // User is on GLP-1 medication (Ozempic/Wegovy/etc)
  todayMode            String    @default("RITUAL") // "RITUAL" | "DASHBOARD"
  onboardingComplete   Boolean   @default(false)
  customInstructions   String?   @db.Text
  customResponseStyle  String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  deleteRequestedAt    DateTime?
  gdprConsentAt        DateTime?
  analyticsConsent     Boolean   @default(false)
  notificationPrefs    Json      @default("{}")
  timezone             String    @default("UTC")
  lastRolloverDate     DateTime?
  totalXp              Int       @default(0)
  currentStreak        Int       @default(0)
  bestStreak           Int       @default(0)

  accounts          Account[]
  sessions          Session[]
  resetTokens       PasswordResetToken[]
  mfaConfigs        MfaConfig[]
  goals             Goal[]
  habits            Habit[]
  habitCompletions  HabitCompletion[]
  workoutLogs       WorkoutLog[]
  scheduledWorkouts ScheduledWorkout[]
  weeklyTargets     WeeklyTarget[]
  dailyLedger       DailyLedger[]
  measurements      Measurement[]
  photos            Photo[]
  checklistItems    ChecklistItem[]
  weeklyReviews     WeeklyReview[]
  achievements      Achievement[]
  streaks           Streak[]
  conversations     Conversation[]
  memories          Memory[]
  notifications     Notification[]
  devices           Device[]
  auditLogs         AuditLog[]
  feedbackItems     MessageFeedback[]
  pushSubscriptions PushSubscription[]
  notificationPreference NotificationPreference?
  notificationLogs       NotificationLog[]
  emails            Email[]
  emailPreference   EmailPreference?
  unsubscribeTokens UnsubscribeToken[]
  chatSuggestions   ChatSuggestion[]
  avatar            Avatar?
  avatarMilestones  AvatarMilestone[]
  avatarEvents      AvatarEvent[]
  safetyFlags       SafetyFlag[]
  healthIntegration     HealthIntegration?
  haeRaw                HaeRaw[]
  haeMetrics            HaeMetric[]
  haeDailies            HaeDaily[]
  haeWorkouts           HaeWorkout[]
  androidWaitlist       HealthAndroidWaitlist?
  glp1Profile           GLP1Profile?
  nutritionLogs         NutritionLog[]
  reactiveAdjustments   ReactiveAdjustmentLog[]
  insightFiredLogs      InsightFiredLog[]
  userFacts             UserFact[]
  plannerConstraints    PlannerConstraint[]
  planValidationLogs    PlanValidationLog[]
  accountabilityPartners AccountabilityPartner[] @relation("UserPartners")
  partnerOf              AccountabilityPartner[] @relation("PartnerOf")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  rememberMe   Boolean  @default(false)
  createdAt    DateTime @default(now())
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MfaConfig {
  id        String   @id @default(cuid())
  userId    String
  type      String
  secret    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ─── Conversations & Messages ─────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  pinned    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String
  content         String   @db.Text
  toolName        String?
  toolCallId      String?
  parentId        String?
  branchIndex     Int      @default(0)
  thinkingContent String?  @db.Text
  createdAt       DateTime @default(now())

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]
  feedback     MessageFeedback[]
  children     Message[]         @relation("MessageBranch")
  parent       Message?          @relation("MessageBranch", fields: [parentId], references: [id])

  @@index([conversationId])
}

model Attachment {
  id         String   @id @default(cuid())
  messageId  String
  type       String
  fileName   String
  mimeType   String
  r2Key      String
  sizeBytes  Int
  transcript String?  @db.Text
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ─── Memory ───────────────────────────────────────────────────────────────────

model Memory {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String?
  content   String    @db.Text
  source    String?
  weekOf    DateTime?
  eventDate DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

// ─── Goals ────────────────────────────────────────────────────────────────────

model Goal {
  id               String     @id @default(cuid())
  userId           String
  // Legacy fields (kept for backward compat)
  description      String?    @db.Text
  direction        String?    // increase / decrease / maintain / achieve
  magnitude        Float?
  bodyArea         String?
  planJson         String?    @db.Text
  // New fields
  title            String?
  category         String?    // body-composition / performance / lifestyle / aesthetic / health
  visionText       String?    @db.Text
  targetMetric     String?    // waist_cm / weight_kg / body_fat_pct / etc.
  startValue       Float?
  currentValue     Float?
  targetValue      Float?
  unit             String?
  deadline         DateTime?
  status           String     @default("active") // active / paused / achieved / archived
  priority         Int        @default(1)
  predictedHitDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits           Habit[]
  scheduledWkts    ScheduledWorkout[]
  measurements     Measurement[]
  avatarMilestones AvatarMilestone[]

  @@index([userId, status])
}

// ─── Habits ───────────────────────────────────────────────────────────────────

model Habit {
  id               String       @id @default(cuid())
  userId           String
  goalId           String?
  title            String?
  description      String?      @db.Text
  cadence          String       @default("daily") // kept as string for compat
  cadenceType      HabitCadence @default(DAILY)
  targetPerWeek    Int?
  specificDays     Int[]        // 0=Sun … 6=Sat
  timeOfDay        String?      // morning / afternoon / evening / anytime
  reminderTime     String?      // "07:30"
  duration         Int?         // minutes
  pointsOnComplete Int          @default(10)
  icon             String?      // lucide icon name
  color            String?      // hex accent
  active           Boolean      @default(true)
  startedAt        DateTime     @default(now())
  pausedAt         DateTime?
  createdAt        DateTime     @default(now())

  // Wearable-driven resolution (Track WD).
  // When trackingMode != MANUAL, the end-of-day Inngest job reads the
  // HealthDaily row matching (userId, today, metric=metricKey) and writes
  // a HabitCompletion DONE/MISSED based on (value, metricComparison, metricTarget).
  // metricKey is the HealthDaily.metric string ("steps", "sleepHours",
  // "activeMinutes", "restingHr", "hrvMs", ...), NOT a column name.
  trackingMode     HabitTrackingMode @default(MANUAL)
  metricKey        String?
  metricTarget     Float?
  metricComparison MetricComparison?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal?             @relation(fields: [goalId], references: [id], onDelete: SetNull)
  completions HabitCompletion[]
  checklistItems ChecklistItem[]

  @@index([userId, active])
  @@index([userId, trackingMode, active])
}

model HabitCompletion {
  id          String           @id @default(cuid())
  habitId     String
  userId      String
  date        DateTime         @db.Date
  status      CompletionStatus @default(DONE)
  source      CompletionSource @default(MANUAL)
  completedAt DateTime?        // null for rollover-created MISSED/SKIPPED entries
  note        String?
  points      Int              @default(0)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@index([userId, status, date])
}

// ─── AI Suggestions ───────────────────────────────────────────────────────────

model ChatSuggestion {
  id          String    @id @default(cuid())
  userId      String
  type        String    // habit_adjustment / goal_nudge / streak_recovery / PLAN_REPLANNED / PLAN_VALIDATION_FAILED
  title       String
  body        String    @db.Text
  habitId     String?   // linked habit if type = habit_adjustment
  payload     Json?     // structured data — used by PLAN_REPLANNED for the changes drawer
  dismissed   Boolean   @default(false)
  appliedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed, createdAt])
}

// ─── Workout Types ────────────────────────────────────────────────────────────

model WorkoutType {
  id              String  @id @default(cuid())
  name            String  @unique
  slug            String? @unique
  defaultMet      Float   @default(5.0)
  defaultDuration Int     @default(45)
  category        String?
  description     String?
  icon            String? // lucide icon name
  color           String? // hex accent

  logs             WorkoutLog[]
  scheduledWorkouts ScheduledWorkout[]
  weeklyTargets    WeeklyTarget[]
}

// ─── Scheduled Workouts ───────────────────────────────────────────────────────

model ScheduledWorkout {
  id             String        @id @default(cuid())
  userId         String
  goalId         String?
  workoutTypeId  String?
  workoutTypeName String?      // fallback if no FK
  scheduledDate  DateTime      @db.Date
  scheduledTime  String?       // "09:00"
  duration       Int           @default(45)
  intensity      Int?
  notes          String?       @db.Text
  status         WorkoutStatus @default(PLANNED)
  source         String        @default("manual") // manual | ai_suggested | imported
  userEdited     Boolean       @default(false)  // user manually moved/edited — planner regen must respect
  completedAt    DateTime?
  skippedReason  String?
  workoutLogId   String?       @unique
  pointsEarned   Int           @default(0)
  createdAt      DateTime      @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal?        @relation(fields: [goalId], references: [id], onDelete: SetNull)
  workoutType WorkoutType? @relation(fields: [workoutTypeId], references: [id])

  @@index([userId, scheduledDate])
  @@index([userId, status])
}

// ─── Weekly Targets ───────────────────────────────────────────────────────────

model WeeklyTarget {
  id              String  @id @default(cuid())
  userId          String
  goalId          String?
  workoutTypeId   String?
  workoutTypeName String? // fallback label
  targetCount     Int
  active          Boolean @default(true)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutType WorkoutType? @relation(fields: [workoutTypeId], references: [id])

  @@index([userId, active])
}

// ─── Daily Ledger ─────────────────────────────────────────────────────────────

model DailyLedger {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @db.Date
  habitsCompleted Int       @default(0)
  habitsTotal     Int       @default(0)
  missedHabits    Int       @default(0)
  skippedHabits   Int       @default(0)
  workoutsDone    Int       @default(0)
  workoutsPlanned Int       @default(0)
  points          Int       @default(0)
  xpDeducted      Int       @default(0)
  streakCount     Int       @default(0)
  allComplete     Boolean   @default(false)
  rolloverAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Workout Logs ─────────────────────────────────────────────────────────────

model WorkoutLog {
  id                String   @id @default(cuid())
  userId            String
  typeId            String?
  workoutName       String
  startedAt         DateTime @default(now())
  durationMin       Int
  intensity         Int?
  perceivedExertion Int?
  caloriesEst       Float?
  heartRateAvg      Int?
  heartRateMax      Int?
  source            String   @default("manual")
  notes             String?  @db.Text
  xpAwarded         Int      @default(25)
  createdAt         DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type WorkoutType? @relation(fields: [typeId], references: [id])

  @@index([userId, startedAt])
}

// ─── Measurements ─────────────────────────────────────────────────────────────

model Measurement {
  id         String   @id @default(cuid())
  userId     String
  goalId     String?
  capturedAt DateTime @default(now())
  kind       String
  value      Float
  unit       String   @default("cm")
  source     String   @default("manual")
  confidence Float?
  notes      String?
  createdAt  DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, kind, capturedAt])
}

model Photo {
  id           String   @id @default(cuid())
  userId       String
  capturedAt   DateTime @default(now())
  r2Key        String
  pose         String
  notes        String?
  analysisJson String?  @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
}

// ─── Checklist (legacy, kept for compat) ─────────────────────────────────────

model ChecklistItem {
  id            String    @id @default(cuid())
  userId        String
  date          String
  description   String    @db.Text
  sourceGoalId  String?
  sourceHabitId String?
  doneAt        DateTime?
  createdAt     DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit? @relation(fields: [sourceHabitId], references: [id])

  @@index([userId, date])
}

model WeeklyReview {
  id                  String    @id @default(cuid())
  userId              String
  weekStart           DateTime
  weekOf              String
  adherencePct        Float?
  workoutsCompleted   Int       @default(0)
  workoutsPlanned     Int       @default(0)
  deltasJson          String?   @db.Text
  aiSummary           String?   @db.Text
  nextWeekAdjustments String?   @db.Text
  acceptedAt          DateTime?
  deliveredAt         DateTime?
  emailSentAt         DateTime?
  createdAt           DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  xpAwarded   Int      @default(0)
  earnedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Streak {
  id        String    @id @default(cuid())
  userId    String
  type      String
  current   Int       @default(0)
  longest   Int       @default(0)
  lastAt    DateTime?
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  body         String    @db.Text
  data         String?   @db.Text
  readAt       DateTime?
  sentAt       DateTime?
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Per-user push notification preferences. One row per user, lazily
// created on first /settings/notifications visit. See lib/notifications/send.ts.
model NotificationPreference {
  userId               String  @id
  preWorkout           Boolean @default(true)
  streakSave           Boolean @default(true)
  weeklyReview         Boolean @default(true)
  reactiveAdjustment   Boolean @default(true)
  partnerEncouragement Boolean @default(true)
  quietHoursStart      String  @default("22:00") // user-local 24h time
  quietHoursEnd        String  @default("07:00")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Audit log of every push attempted. Used for the >2-per-24h throttle and
// for surfacing delivery health on /admin.
model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  category  String   // "preWorkout" | "streakSave" | "weeklyReview" | "reactiveAdjustment" | "partnerEncouragement"
  title     String
  body      String
  deepLink  String?
  sentAt    DateTime @default(now())
  delivered Boolean  @default(false)
  clicked   Boolean  @default(false)
  skipReason String? // populated when send.ts decided not to send (quiet hours, prefs off, throttle)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([userId, category, sentAt])
}

// ─── Wearables ────────────────────────────────────────────────────────────────

model Device {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  terraUserId  String?   @unique
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  connected    Boolean   @default(true)
  status       String    @default("CONNECTED")
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceData DeviceData[]

  @@unique([userId, provider])
}

model DeviceData {
  id              String   @id @default(cuid())
  deviceId        String
  date            String
  steps           Int?
  activeMinutes   Int?
  caloriesBurned  Float?
  hrAvg           Int?
  hrMax           Int?
  hrMin           Int?
  hrResting       Int?
  hrv             Float?
  sleepDuration   Int?
  sleepEfficiency Float?
  bodyTempDelta   Float?
  readinessScore  Float?
  recoveryScore   Float?
  menstrualPhase  String?
  rawJson         String?  @db.Text
  createdAt       DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, date])
  @@index([deviceId, date])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  details    String?  @db.Text
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─── Email System ─────────────────────────────────────────────────────────────

model Email {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  subject    String
  to         String
  resendId   String?     @unique
  status     EmailStatus @default(QUEUED)
  sentAt     DateTime?
  metadata   Json?
  createdAt  DateTime    @default(now())
  events     EmailEvent[]

  @@index([userId, createdAt])
  @@index([templateId])
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  COMPLAINED
  OPENED
  CLICKED
  FAILED
  SUPPRESSED
  PREFERENCE_BLOCKED
}

model EmailEvent {
  id        String   @id @default(cuid())
  emailId   String
  email     Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model EmailPreference {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyMorningPlan  Boolean  @default(true)
  tomorrowEvening   Boolean  @default(false)
  weeklyReview      Boolean  @default(true)
  monthlyReport     Boolean  @default(true)
  workoutReminders  Boolean  @default(true)
  measurementNudges Boolean  @default(true)
  photoNudges       Boolean  @default(true)
  milestones        Boolean  @default(true)
  winback           Boolean  @default(true)
  birthday          Boolean  @default(true)
  onboardingSeries  Boolean  @default(true)
  morningTime       String   @default("07:00")
  eveningTime       String   @default("20:00")
  timezone          String   @default("UTC")
  updatedAt         DateTime @updatedAt
}

model EmailSuppression {
  email     String   @id
  reason    String
  createdAt DateTime @default(now())
}

model UnsubscribeToken {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String?
  createdAt DateTime @default(now())
}

// ─── Avatar System ────────────────────────────────────────────────────────────

// ─── GLP-1 Muscle Defense ─────────────────────────────────────────────────────

model GLP1Profile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  active                Boolean   @default(false)
  medication            String?   // "semaglutide" | "tirzepatide" | "liraglutide" | "other"
  startedOn             DateTime?
  doseSchedule          String?   // "weekly" | "biweekly" | "daily"
  proteinTargetG        Int?      // g/day, computed from body weight × 1.6
  resistanceMinTarget   Int?      // minutes/week of resistance training, default 150
  notes                 String?   @db.Text
  weeklyReviewedAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

