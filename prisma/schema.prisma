// ───────────────────────────────────────────────────────────────────────────
// Planner constraints — first-class user inputs that the validator + replanner
// query on every plan generation. See PLANNER.md for the full architecture.
// ───────────────────────────────────────────────────────────────────────────

enum ConstraintType {
  TREATMENT             // microneedling, botox, dental, surgery — payload: { treatmentName, restrictions[] }
  INJURY                // knee, lower back — payload: { bodyPart, severity, allowedActivities[] }
  ILLNESS               // cold, flu — payload: { severity, suggestedRestUntil }
  TRAVEL                // payload: { departureDate, returnDate, destination, equipmentAvailable[] }
  SCHEDULE_BLACKOUT     // unavailable on these days/times — payload: { weekdays[], timeRanges[] }
  ACTIVITY_RESTRICTION  // no heat, no high-impact — payload: { restrictedTags[], reason }
  PREFERENCE            // morning person, hates burpees — payload: { type, value }
  CYCLE_PHASE           // late luteal, period — payload: { phase, intensity }
  RECOVERY_REQUIREMENT  // rest day Sunday, 48h between heavy lifts — payload: { rule }
}

enum ConstraintScope {
  HARD     // never violate, plan must accommodate
  SOFT     // prefer not to violate, allow if no alternative
  ADVISORY // surface as info only
}

model PlannerConstraint {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       ConstraintType
  scope      ConstraintScope
  startDate  DateTime        @db.Date
  endDate    DateTime?       @db.Date
  payload    Json
  reason     String          @db.Text
  source     String          // "user_chat" | "manual_settings" | "system_rule" | "wearable_inferred"
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  resolvedAt DateTime?

  @@index([userId, active, startDate, endDate])
  @@index([userId, type])
}

model PlanValidationLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  attemptCount Int      @default(1)
  finalStatus  String   // "PASSED" | "PASSED_WITH_WARNINGS" | "FAILED_USER_NOTIFIED"
  violations   Json
  finalPlan    Json
  createdAt    DateTime @default(now())

  @@index([userId, date])
}

// Temporal-rules canary. The hourly dataIntegritySweep writes a row here
// whenever it finds a violation in the live data. Rows are kept for
// post-incident audit; resolvedAt is set by the next clean sweep. See
// CALENDAR_RULES.md.
// ───────────────────────────────────────────────────────────────────────────
// Accountability partner v1 — see TRACK_B.md.
// One partner per user (privacy by default; never measurements/photos/goal
// text). Weekly summary email Sunday 10:00 user-local. One encouragement
// per ISO week from partner -> user.
// ───────────────────────────────────────────────────────────────────────────

enum PartnerStatus {
  PENDING   // invite sent, partner hasn't clicked accept yet
  ACCEPTED  // active partnership, weekly emails firing
  DECLINED  // partner explicitly declined
  ENDED     // either side ended the partnership
}

enum ShareLevel {
  MINIMAL   // streak count only
  STANDARD  // workouts done/planned, habit %, streak
  // never: weight, body fat, measurements, goal text, photos
}

model AccountabilityPartner {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation("UserPartners", fields: [userId], references: [id], onDelete: Cascade)
  partnerEmail  String
  partnerName   String
  partnerUserId String?
  partnerUser   User?         @relation("PartnerOf", fields: [partnerUserId], references: [id], onDelete: SetNull)
  status        PartnerStatus @default(PENDING)
  invitedAt     DateTime      @default(now())
  acceptedAt    DateTime?
  endedAt       DateTime?
  inviteToken   String        @unique
  shareLevel    ShareLevel    @default(STANDARD)

  encouragements PartnerEncouragement[]

  @@index([userId, status])
  @@index([partnerEmail])
}

model PartnerEncouragement {
  id          String                @id @default(cuid())
  partnerId   String
  partner     AccountabilityPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  message     String                @db.Text  // max 280 chars enforced in handler
  sentAt      DateTime              @default(now())
  weekOfYear  Int   // ISO week 1..53; with yearNumber forms a unique slot per partner per week
  yearNumber  Int
  readAt      DateTime?

  @@unique([partnerId, weekOfYear, yearNumber])
  @@index([partnerId, sentAt])
}

model IntegrityAlert {
  id         String    @id @default(cuid())
  detectedAt DateTime  @default(now())
  table      String    // "ScheduledWorkout" | "WorkoutLog" | "HabitCompletion"
  rule       String    // e.g. "future-completed", "log-startedAt-future"
  count      Int
  sample     Json      // up to 5 row IDs + key fields
  resolvedAt DateTime?

  @@index([detectedAt])
  @@index([resolvedAt])
}
